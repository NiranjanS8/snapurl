DB_URL=jdbc:mysql://mysql:3306/snap_url
DB_USERNAME=snapurl
DB_PASSWORD=replace-with-local-db-password

MYSQL_DATABASE=snap_url
MYSQL_USER=snapurl
MYSQL_PASSWORD=replace-with-local-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-local-mysql-root-password

JWT_SECRET=replace-with-a-long-base64-secret
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
RATE_LIMIT_FAIL_OPEN=true
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
MANAGEMENT_SERVER_PORT=9091
PROMETHEUS_HOST_PORT=9095
GRAFANA_HOST_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000/snap/share/go/dashboard/
GRAFANA_ADMIN_USER=replace-with-local-grafana-login
GRAFANA_ADMIN_PASSWORD=replace-with-local-grafana-password
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

MAIL_ENABLED=false
MAIL_FROM=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EXPOSE_RESET_CODE=false

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=replace-with-local-rabbitmq-user
RABBITMQ_PASSWORD=replace-with-local-rabbitmq-password
