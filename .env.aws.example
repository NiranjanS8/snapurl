JWT_SECRET=replace-with-a-long-base64-secret
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
MANAGEMENT_SERVER_PORT=9091
PROMETHEUS_HOST_PORT=9095
